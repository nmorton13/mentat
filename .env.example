# MENTAT environment example
# Copy to .env and fill in values as needed.
# Do not commit your real .env file.

# =============================================================================
# Required / common API keys
# =============================================================================

# Required for OpenRouter-backed chat, feature routes, and online/web calls.
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: needed for OpenAI voice realtime or direct OpenAI usage.
OPENAI_API_KEY=

# Optional: needed for xAI voice realtime when VOICE_PROVIDER=xai.
XAI_API_KEY=

# Optional: default user id.
MENTAT_USER_ID=mentat

# =============================================================================
# Normal chat model
# =============================================================================

# Default OpenRouter model when normal chat is using OpenRouter.
# The interactive /model selector can override this at runtime.
OPENROUTER_MODEL=x-ai/grok-4.5

# Optional: route normal chat/capture/summaries to a local/OpenAI-compatible server.
# Leave CHAT_* unset/commented to use OpenRouter for normal chat.
#CHAT_BASE_URL=http://localhost:1234/v1
#CHAT_API_KEY=local
#CHAT_MODEL=google/gemma-4-12b-qat

# =============================================================================
# Reusable local provider for feature-specific routing
# =============================================================================

# LOCAL_* does not replace CHAT_*.
# It defines a reusable local provider for features with PROVIDER=local.
# You only need this if a feature route uses provider=local.
#LOCAL_BASE_URL=http://localhost:1234/v1
#LOCAL_API_KEY=local
#LOCAL_MODEL=google/gemma-4-12b-qat

# =============================================================================
# Online / web-backed calls
# =============================================================================

# Optional: OpenRouter model for explicit online/research chat calls.
# This is separate from /capture -w web enrichment; /link does not access the web.
# Online/web calls require OPENROUTER_API_KEY and always route through OpenRouter.
# If unset, local/custom chat falls back to OPENROUTER_MODEL for online/web calls.
ONLINE_MODEL=google/gemini-3.1-flash-lite

# =============================================================================
# Per-feature LLM routing
# =============================================================================

# Provider options:
#   chat       = use active normal chat client/model (default)
#                /model changes this active chat model at runtime.
#   openrouter = use OPENROUTER_API_KEY + OPENROUTER_BASE_URL
#   local      = use LOCAL_BASE_URL/LOCAL_API_KEY/LOCAL_MODEL
#   ollama     = use native Ollama /api/chat via OLLAMA_BASE_URL/OLLAMA_MODEL
#   custom     = use feature-specific <FEATURE>_BASE_URL and <FEATURE>_API_KEY
# HELPERS_* sets shared defaults for helper/task routes. Explicit feature
# provider/model overrides still win and do not change when /model changes chat.
HELPERS_PROVIDER=
HELPERS_MODEL=

# Optional: native Ollama route. This is separate from OpenAI-compatible local
# servers and uses Ollama's /api/chat endpoint.
#OLLAMA_BASE_URL=http://localhost:11434
#OLLAMA_MODEL=llama3.2
#OLLAMA_THINK=false
#OLLAMA_TEMPERATURE=1.0
#OLLAMA_TOP_P=0.95
#OLLAMA_TOP_K=64

# ConceptExplorer tree generation.
CONCEPT_EXPLORATION_PROVIDER=
CONCEPT_EXPLORATION_MODEL=
CONCEPT_EXPLORATION_DEFAULT_DEPTH=2
CONCEPT_EXPLORATION_MAX_CONCEPTS=4
CONCEPT_EXPLORATION_BATCH_SIZE=4

# Entity extraction for memories/chat context.
ENTITY_EXTRACTION_PROVIDER=
ENTITY_EXTRACTION_MODEL=

# Concept connection analysis.
CONCEPT_CONNECTION_PROVIDER=
CONCEPT_CONNECTION_MODEL=

# Capture analysis/classification.
CAPTURE_ANALYSIS_PROVIDER=
CAPTURE_ANALYSIS_MODEL=

# Todo extraction.
TODO_EXTRACTION_PROVIDER=
TODO_EXTRACTION_MODEL=

# Temporal/date intent parsing.
TEMPORAL_INTENT_PROVIDER=
TEMPORAL_INTENT_MODEL=

# Example: local normal chat, but OpenRouter for structured feature tasks:
#CHAT_BASE_URL=http://localhost:1234/v1
#CHAT_API_KEY=local
#CHAT_MODEL=google/gemma-4-12b-qat
#HELPERS_PROVIDER=openrouter
#HELPERS_MODEL=google/gemini-3.1-flash-lite
#TEMPORAL_INTENT_MODEL=google/gemini-3.1-pro

# =============================================================================
# Model/runtime settings
# =============================================================================

MODEL_CONFIG_PATH=config/models.json
RUNTIME_SETTINGS_PATH=data/runtime_settings.json

# =============================================================================
# Retrieval / memory tuning
# =============================================================================

CHAT_MEMORY_K=10
SEARCH_RESULTS_K=8
PROJECT_ANALYSIS_K=25
SYNTHESIS_K=15
CHAT_MIN_SIMILARITY=0.2
SEMANTIC_SEARCH_MIN_SIMILARITY=0.1

# Enhanced chat scales automatically with the number of saved memories:
# up to 25 primary results, 75 internal candidates, and 50 prompt memories.
# Uncomment any value below to override that part of the automatic tuning.
# CHAT_HYBRID_SEARCH_K=25
# HYBRID_SEARCH_INTERNAL_MULTIPLIER=3.0
# CHAT_CONTEXT_LIMIT=50

# =============================================================================
# Database / export
# =============================================================================

DATABASE_PATH=data/mentat.db
MARKDOWN_EXPORT_ENABLED=true
MARKDOWN_EXPORT_PATH=data/markdown

# =============================================================================
# Voice capture
# =============================================================================

VOICE_PROVIDER=openai
VOICE_MODEL=gpt-realtime-mini
VOICE_NAME=alloy
VOICE_AUTO_CAPTURE=false
VOICE_CAPTURE_TYPE=voice_conversation
VOICE_CAPTURE_PROMPT_TIMEOUT=30
VOICE_SUGGEST_CAPTURES=true

# xAI voice example:
#VOICE_PROVIDER=xai
#VOICE_MODEL=replace_with_xai_realtime_model
#VOICE_NAME=Ara
